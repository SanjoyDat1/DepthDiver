# Copy to ".env" in this folder (never commit real secrets).

# Anthropic — required for Pro mode (Claude Scene Intelligence + Quality Report).
# Get a key at https://console.anthropic.com/ (free tier / pay-as-you-go).
ANTHROPIC_API_KEY=your_key_here

# Optional: default Claude model id (must match a model your key can call).
# Examples: claude-3-5-sonnet-20241022, claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: SHARP device — cuda | mps | cpu (omit to auto-detect)
# SHARP_DEVICE=mps

# Optional: custom SHARP checkpoint .pt (passed as `sharp predict -c`).
# Default model auto-downloads if unset.
# SHARP_CHECKPOINT_PATH=/path/to/sharp_2572gikvuh.pt

# Optional: Gradio bind
# GRADIO_SERVER_NAME=127.0.0.1
# GRADIO_SERVER_PORT=7860
